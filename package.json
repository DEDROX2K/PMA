{
  "name": "airpaste",
  "version": "0.1.0",
  "private": true,
  "author": "ragha",
  "description": "A local-first desktop canvas for link and note capture.",
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config vite.config.mjs",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "start": "electron .",
    "lint": "eslint .",
    "build": "vite build --config vite.config.mjs",
    "package": "npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "open-graph-scraper": "^6.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "vite": "^7.1.11",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.airpaste.app",
    "productName": "AirPaste",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-renderer/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
